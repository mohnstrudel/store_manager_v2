header.nav_header
  .flex.gap-4
    hgroup
      - if sale.shopify_name.present? || sale.shopify_id.present?
        h1
          .inline-block.icon-shopify.w-13.h-13.mr-3.-mb-1
          | Sale #{sale.shopify_name.presence || sale.shopify_id}
      - elsif sale.woo_id.present?
        h1
          .inline-block.icon-woo.w-17.h-17.mr-4.-mb-4
          | Sale #{sale.woo_id}
      h2 = [sale.status&.titleize, sale.customer.email.presence].compact.join(" | ")
  menu.nav_menu
    - if sale.shopify_name.present? || sale.shopify_id.present?
      li = pull_btn_for sale
    li = shop_admin_link(sale)
    li = edit_btn_for sale
