{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(brew search:*)",
      "Bash(brew info:*)",
      "Bash(brew list:*)",
      "Bash(brew update:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(open:*)",
      "Bash(docker pull:*)",
      "Bash(docker run:*)",
      "Bash(ollama pull:*)",
      "Bash(ollama list:*)",
      "Bash(rails g migration:*)",
      "Bash(bundle exec rails generate migration:*)",
      "Bash(bin/rails g migration:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(rails c:*)",
      "Bash(bundle exec rubocop:*)",
      "Bash(rubocop:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(mv:*)"
    ]
  }
}
