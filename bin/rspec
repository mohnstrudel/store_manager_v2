#!/usr/bin/env ruby
# frozen_string_literal: true

if ENV["PARALLEL_TEST_GROUPS"] || ENV["TEST_ENV_NUMBER"]
  ENV["DISABLE_SIMPLECOV"] = "1"
  require_relative "../config/boot"
  load Gem.bin_path("rspec-core", "rspec")
elsif (ENV["CI"] && !ENV["CI"].empty?) || (ENV["PARALLEL_TEST_PROCESSORS"] && !ENV["PARALLEL_TEST_PROCESSORS"].empty?)
  load File.expand_path("parallel-rspec", __dir__)
else
  require_relative "../config/boot"
  load Gem.bin_path("rspec-core", "rspec")
end
